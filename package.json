{
  "name": "dashboard",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "lint:cycles": "madge --circular --extensions ts,tsx --ts-config ./tsconfig.json ./src",
    "db:create": "mikro-orm schema:create --run",
    "db:update": "mikro-orm schema:update --run",
    "db:drop": "mikro-orm schema:drop --run",
    "db:seed": "npx tsx scripts/seed.ts",
    "db:migrate": "mikro-orm migration:up",
    "db:migrate:down": "mikro-orm migration:down",
    "db:migrate:create": "mikro-orm migration:create",
    "db:migrate:pending": "mikro-orm migration:pending",
    "db:migrate:fresh": "mikro-orm migration:fresh"
  },
  "mikro-orm": {
    "useTsNode": true,
    "configPaths": [
      "./src/db/mikro-orm.config.ts"
    ]
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1009.0",
    "@mikro-orm/cli": "^6.6.9",
    "@mikro-orm/core": "^6.6.9",
    "@mikro-orm/migrations": "^6.6.9",
    "@mikro-orm/postgresql": "^6.6.9",
    "bcryptjs": "^3.0.3",
    "next": "16.1.6",
    "next-auth": "^4.24.13",
    "qrcode": "^1.5.4",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/pg": "^8.18.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "eslint-plugin-import": "^2.32.0",
    "madge": "^8.0.0",
    "tailwindcss": "^4",
    "ts-node": "^10.9.2",
    "typescript": "^5"
  }
}
