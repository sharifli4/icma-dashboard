{
  "name": "dashboard",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "lint:cycles": "madge --circular --extensions ts,tsx --ts-config ./tsconfig.json ./src",
    "db:create": "mikro-orm schema:create --run",
    "db:update": "mikro-orm schema:update --run",
    "db:drop": "mikro-orm schema:drop --run"
  },
  "mikro-orm": {
    "useTsNode": true,
    "configPaths": [
      "./src/db/mikro-orm.config.ts"
    ]
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1009.0",
    "@mikro-orm/cli": "^6.6.9",
    "@mikro-orm/core": "^6.6.9",
    "@mikro-orm/postgresql": "^6.6.9",
    "next": "16.1.6",
    "qrcode": "^1.5.4",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "eslint-plugin-import": "^2.32.0",
    "madge": "^8.0.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
