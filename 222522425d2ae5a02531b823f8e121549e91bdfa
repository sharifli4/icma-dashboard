  const fetchSessions = async () => {\n    setLoadingSessions(true);\n    setPoolError(null);\n    try {\n      const response = await fetch(\"/api/hackathon/sessions\");\n      const json = await response.json();\n      if (!response.ok) throw new Error(json.error || \"Failed to fetch sessions\");\n      setSessions(json.data);\n      if (json.data.length > 0 && !selectedSession) {\n        setSelectedSession(json.data[0]);\n        fetchSubmissions(json.data[0].token);\n      }\n    } catch (err) {\n      setPoolError(err instanceof Error ? err.message : \"An error occurred\");\n    } finally {\n      setLoadingSessions(false);\n    }\n  };\n\n  const fetchSubmissions = async (token: string) => {\n    setLoadingSubmissions(true);\n    try {\n      const response = await fetch(`/api/hackathon/sessions/${token}/submissions`);\n      const json = await response.json();\n      if (!response.ok) throw new Error(json.error || \"Failed to fetch submissions\");\n      setSubmissions(json.data);\n    } catch (err) {\n      setPoolError(err instanceof Error ? err.message : \"An error occurred\");\n    } finally {\n      setLoadingSubmissions(false);\n    }\n  };\n\n  const handleSessionSelect = (s: HackathonSessionData) => {\n    setSelectedSession(s);\n    fetchSubmissions(s.token);\n  };\n\n  const isSessionActive = (s: HackathonSessionData) => {\n    const now = new Date();\n    return now >= new Date(s.startDate) && now <= new Date(s.endDate);\n  };\n\n  const formatDate = (dateString: string) => new Date(dateString).toLocaleString();\n\n  // Create handlers\n  const handleCreate = async (e: React.FormEvent) => {\n    e.preventDefault();\n    setCreating(true);\n    setCreateError(null);\n\n    try {\n      const response = await fetch(\"/api/hackathon/sessions\", {\n        method: \"POST\",\n        headers: { \"Content-Type\": \"application/json\" },\n        body: JSON.stringify({\n          eventName,\n          startDate: new Date(startDate).toISOString(),\n          endDate: new Date(endDate).toISOString(),\n        }),\n      });\n\n      const json = await response.json();\n      if (!response.ok) throw new Error(json.error || \"Failed to create session\");\n      setCreateResult(json.data);\n    } catch (err) {\n      setCreateError(err instanceof Error ? err.message : \"An error occurred\");\n    } finally {\n      setCreating(false);\n    }\n  };\n\n  const getSubmitUrl = () => {\n    if (!createResult) return \"\";\n    return `${window.location.origin}${createResult.submitPath}`;\n  };\n\n  const copyToClipboard = async () => {\n    await navigator.clipboard.writeText(getSubmitUrl());\n    setCopied(true);\n    setTimeout(() => setCopied(false), 2000);\n  };\n\n  const resetCreate = () => {\n    setCreateResult(null);\n    setEventName(\"\");\n    setStartDate(\"\");\n    setEndDate(\"\");\n    // Refresh sessions list to include the new one\n    fetchSessions();\n    setActiveTab(\"pool\");\n  };\n\n  return (\n    <div className=\"min-h-screen flex flex-col\">\n      {/* Navbar */}\n      <header className=\"border-b-2 border-[var(--border)] px-6 py-3 flex items-center justify-between sticky top-0 bg-white z-50\">\n        <a href=\"/\" className=\"flex items-center gap-2 font-bold text-lg tracking-tight\">\n          <img src=\"/icma_logo.svg\" alt=\"ICMA.IO\" className=\"w-7 h-7\" />\n          ICMA.IO\n        </a>\n        <span className=\"text-xs font-bold text-[var(--muted)] uppercase\">HackPool</span>\n      </header>\n\n      {/* Tab Bar */}\n      <div className=\"border-b-2 border-[var(--border)] bg-white sticky top-[57px] z-40\">\n        <div className=\"max-w-6xl mx-auto px-6 flex gap-0\">\n          <button\n            onClick={() => setActiveTab(\"pool\")}\n            className={`px-5 py-3 text-sm font-bold uppercase tracking-wider border-b-2 transition-colors ${\n              activeTab === \"pool\"\n                ? \"border-[var(--accent)] text-[var(--foreground)]\"\n                : \"border-transparent text-[var(--muted)] hover:text-[var(--foreground)]\"\n            }`}\n          >\n            Projects_Pool\n          </button>\n          {session && (\n            <button\n              onClick={() => setActiveTab(\"create\")}\n              className={`px-5 py-3 text-sm font-bold uppercase tracking-wider border-b-2 transition-colors ${\n                activeTab === \"create\"\n                  ? \"border-[var(--accent)] text-[var(--foreground)]\"\n                  : \"border-transparent text-[var(--muted)] hover:text-[var(--foreground)]\"\n              }`}\n            >\n              + New_Session\n            </button>\n          )}\n        </div>\n      </div>\n\n      {/* Content */}\n      {activeTab === \"pool\" ? (\n        <div className=\"flex flex-1\">\n          {/* Sidebar - Sessions List */}\n          <aside className=\"w-72 border-r-2 border-[var(--border)] p-5 flex-shrink-0 sticky top-[114px] self-start h-[calc(100vh-114px)] overflow-y-auto\">\n            <div className=\"flex items-center justify-between mb-4\">\n              <h2 className=\"text-xs font-bold uppercase tracking-wider text-[var(--muted)]\">\n                Sessions\n              </h2>\n              <button\n                onClick={fetchSessions}\n                className=\"p-1.5 border-2 border-[var(--border)] hover:bg-gray-100 transition-colors\"\n                title=\"Refresh\"\n              >\n                <RefreshIcon />\n              </button>\n            </div>\n\n            {loadingSessions ? (\n              <div className=\"text-sm text-[var(--muted)]\">Loading...</div>\n            ) : sessions.length === 0 ? (\n              <div className=\"text-sm text-[var(--muted)]\">No sessions found</div>\n            ) : (\n              <div className=\"space-y-2\">\n                {sessions.map((s) => (\n                  <button\n                    key={s.id}\n                    onClick={() => handleSessionSelect(s)}\n                    className={`w-full text-left p-3 border-2 transition-colors ${\n                      selectedSession?.id === s.id\n                        ? \"bg-[var(--accent)] border-[var(--border)]\"\n                        : \"border-[var(--border)] hover:bg-gray-50\"\n                    }`}\n                  >\n                    <div className=\"font-bold text-sm uppercase truncate\">{s.eventName}</div>\n                    <div className=\"text-xs text-[var(--muted)] mt-1\">\n                      {new Date(s.startDate).toLocaleDateString()}\n                    </div>\n                    <div className=\"mt-2\">\n                      <span\n                        className={`text-xs font-bold px-2 py-0.5 border ${\n                          isSessionActive(s)\n                            ? \"border-green-500 text-green-700 bg-green-50\"\n                            : \"border-gray-400 text-gray-600 bg-gray-50\"\n                        }`}\n                      >\n                        {isSessionActive(s) ? \"ACTIVE\" : \"CLOSED\"}\n                      </span>\n                    </div>\n                  </button>\n                ))}\n              </div>\n            )}\n          </aside>\n\n          {/* Main - Submissions */}\n          <main className=\"flex-1 p-6 lg:p-8\">\n            {poolError && (\n              <div className=\"border-2 border-red-500 bg-red-50 px-4 py-3 text-sm text-red-700 font-mono mb-6\">\n                {poolError}\n              </div>\n            )}\n\n            {selectedSession ? (\n              <>\n                <div className=\"mb-6\">\n                  <h1 className=\"text-2xl font-bold uppercase tracking-tight\">\n                    {selectedSession.eventName}\n                  </h1>\n                  <p className=\"text-sm text-[var(--muted)] mt-1\">\n                    {formatDate(selectedSession.startDate)} — {formatDate(selectedSession.endDate)}\n                  </p>\n                </div>\n\n                <div className=\"flex items-center justify-between mb-4\">\n                  <h2 className=\"text-lg font-bold uppercase\">\n                    Submissions ({submissions.length})\n                  </h2>\n                  <button\n                    onClick={() => fetchSubmissions(selectedSession.token)}\n                    className=\"flex items-center gap-2 px-3 py-1.5 text-sm font-bold border-2 border-[var(--border)] hover:bg-gray-100 transition-colors\"\n                  >\n                    <RefreshIcon />\n                    REFRESH\n                  </button>\n                </div>\n\n                {loadingSubmissions ? (\n                  <div className=\"text-sm text-[var(--muted)]\">Loading submissions...</div>\n                ) : submissions.length === 0 ? (\n                  <div className=\"border-2 border-dashed border-[var(--border)] p-8 text-center\">\n                    <p className=\"text-[var(--muted)]\">No submissions yet</p>\n                  </div>\n                ) : (\n                  <div className=\"space-y-4\">\n                    {submissions.map((submission) => (\n                      <div\n                        key={submission.id}\n                        className=\"border-2 border-[var(--border)] p-5 hover:shadow-[4px_4px_0px_var(--border)] transition-shadow\"\n                      >\n                        <div className=\"flex items-start justify-between gap-4\">\n                          <div className=\"flex-1\">\n                            <h3 className=\"text-lg font-bold uppercase\">{submission.projectName}</h3>\n                            <p className=\"text-sm text-[var(--muted)] mt-1\">\n                              Team: <span className=\"font-bold text-[var(--foreground)]\">{submission.team}</span>\n                            </p>\n                          </div>\n                          <div className=\"text-xs text-[var(--muted)]\">\n                            {formatDate(submission.createdAt)}\n                          </div>\n                        </div>\n\n                        <div className=\"flex flex-wrap gap-3 mt-4\">\n                          <a\n                            href={submission.demoUrl}\n                            target=\"_blank\"\n                            rel=\"noopener noreferrer\"\n                            className=\"flex items-center gap-1.5 px-3 py-1.5 text-xs font-bold border-2 border-[var(--border)] hover:bg-[var(--accent)] transition-colors\"\n                          >\n                            <LinkIcon />\n                            DEMO\n                          </a>\n                          <a\n                            href={submission.githubUrl}\n                            target=\"_blank\"\n                            rel=\"noopener noreferrer\"\n                            className=\"flex items-center gap-1.5 px-3 py-1.5 text-xs font-bold border-2 border-[var(--border)] hover:bg-gray-100 transition-colors\"\n                          >\n                            <GithubIcon />\n                            GITHUB\n                          </a>\n                          <a\n                            href={submission.demoVideoUrl}\n                            target=\"_blank\"\n                            rel=\"noopener noreferrer\"\n                            className=\"flex items-center gap-1.5 px-3 py-1.5 text-xs font-bold border-2 border-[var(--border)] hover:bg-gray-100 transition-colors\"\n                          >\n                            <VideoIcon />\n                            VIDEO\n                          </a>\n                        </div>\n                      </div>\n                    ))}\n                  </div>\n                )}\n              </>\n            ) : (\n              <div className=\"text-center py-12\">\n                <p className=\"text-[var(--muted)]\">Select a session to view submissions</p>\n              </div>\n            )}\n          </main>\n        </div>\n      ) : (\n        /* Create Session Tab */\n        <main className=\"flex-1 p-6 lg:p-8 max-w-2xl mx-auto w-full\">\n          {!createResult ? (\n            <form onSubmit={handleCreate} className=\"space-y-5 mt-4\">\n              <div>\n                <label className=\"block text-xs font-bold uppercase tracking-wider mb-2 text-[var(--muted)]\">\n                  Event_Name\n                </label>\n                <input\n                  type=\"text\"\n                  value={eventName}\n                  onChange={(e) => setEventName(e.target.value)}\n                  className=\"w-full border-2 border-[var(--border)] px-4 py-2.5 text-sm font-mono bg-transparent outline-none focus:ring-2 focus:ring-[var(--accent)]\"\n                  placeholder=\"e.g. AI Hackathon 2026\"\n                />\n              </div>\n\n              <div className=\"grid grid-cols-2 gap-4\">\n                <div>\n                  <label className=\"block text-xs font-bold uppercase tracking-wider mb-2 text-[var(--muted)]\">\n                    <span className=\"flex items-center gap-1.5\">\n                      <CalendarIcon />\n                      Start_Date\n                    </span>\n                  </label>\n                  <input\n                    type=\"datetime-local\"\n                    value={startDate}\n                    onChange={(e) => setStartDate(e.target.value)}\n                    className=\"w-full border-2 border-[var(--border)] px-4 py-2.5 text-sm font-mono bg-transparent outline-none focus:ring-2 focus:ring-[var(--accent)]\"\n                  />\n                </div>\n                <div>\n                  <label className=\"block text-xs font-bold uppercase tracking-wider mb-2 text-[var(--muted)]\">\n                    <span className=\"flex items-center gap-1.5\">\n                      <CalendarIcon />\n                      End_Date\n                    </span>\n                  </label>\n                  <input\n                    type=\"datetime-local\"\n                    value={endDate}\n                    onChange={(e) => setEndDate(e.target.value)}\n                    className=\"w-full border-2 border-[var(--border)] px-4 py-2.5 text-sm font-mono bg-transparent outline-none focus:ring-2 focus:ring-[var(--accent)]\"\n                  />\n                </div>\n              </div>\n\n              {createError && (\n                <div className=\"border-2 border-red-500 bg-red-50 px-4 py-3 text-sm text-red-700 font-mono\">\n                  {createError}\n                </div>\n              )}\n\n              <button\n                type=\"submit\"\n                disabled={creating}\n                className=\"w-full bg-[var(--accent)] border-2 border-[var(--border)] px-6 py-3 text-sm font-bold uppercase hover:bg-[var(--accent-hover)] transition-colors disabled:opacity-50 disabled:cursor-not-allowed\"\n              >\n                {creating ? \"CREATING...\" : \"CREATE_SESSION\"}\n              </button>\n            </form>\n          ) : (\n            <div className=\"space-y-6 mt-4\">\n              <div className=\"border-2 border-green-500 bg-green-50 px-4 py-3 text-sm text-green-700 font-mono\">\n                Session created successfully!\n              </div>\n\n              <div className=\"border-2 border-[var(--border)] p-6\">\n                <h2 className=\"text-lg font-bold uppercase mb-4\">Session_Details</h2>\n\n                <div className=\"space-y-3 text-sm font-mono mb-6\">\n                  <div className=\"flex justify-between\">\n                    <span className=\"text-[var(--muted)]\">Event_Name:</span>\n                    <span className=\"font-bold\">{createResult.eventName}</span>\n                  </div>\n                  <div className=\"flex justify-between\">\n                    <span className=\"text-[var(--muted)]\">Token:</span>\n                    <span className=\"font-bold truncate max-w-[200px]\">{createResult.token}</span>\n                  </div>\n                  <div className=\"flex justify-between\">\n                    <span className=\"text-[var(--muted)]\">Start:</span>\n                    <span className=\"font-bold\">{new Date(createResult.startDate).toLocaleString()}</span>\n                  </div>\n                  <div className=\"flex justify-between\">\n                    <span className=\"text-[var(--muted)]\">End:</span>\n                    <span className=\"font-bold\">{new Date(createResult.endDate).toLocaleString()}</span>\n                  </div>\n                </div>\n\n                <div className=\"border-t-2 border-[var(--border)] pt-6\">\n                  <h3 className=\"text-sm font-bold uppercase mb-3 text-[var(--muted)]\">Submission_URL</h3>\n                  <div className=\"flex gap-2\">\n                    <input\n                      type=\"text\"\n                      readOnly\n                      value={getSubmitUrl()}\n                      className=\"flex-1 border-2 border-[var(--border)] px-3 py-2 text-sm font-mono bg-gray-50\"\n                    />\n                    <button\n                      onClick={copyToClipboard}\n                      className=\"border-2 border-[var(--border)] px-4 py-2 text-sm font-bold hover:bg-gray-100 transition-colors flex items-center gap-2\"\n                    >\n                      {copied ? <CheckIcon /> : <CopyIcon />}\n                      {copied ? \"COPIED\" : \"COPY\"}\n                    </button>\n                  </div>\n                </div>\n\n                <div className=\"border-t-2 border-[var(--border)] pt-6 mt-6\">\n                  <h3 className=\"text-sm font-bold uppercase mb-4 text-[var(--muted)]\">QR_Code</h3>\n                  <div\n                    className=\"flex justify-center p-6 bg-white border-2 border-[var(--border)]\"\n                    dangerouslySetInnerHTML={{ __html: createResult.qrCodeSvg }}\n                  />\n                  <p className=\"text-xs text-[var(--muted)] text-center mt-3\">\n                    Participants can scan this QR code to submit their projects\n                  </p>\n                </div>\n              </div>\n\n              <button\n                onClick={resetCreate}\n                className=\"w-full bg-[var(--accent)] border-2 border-[var(--border)] px-6 py-3 text-sm font-bold uppercase hover:bg-[var(--accent-hover)] transition-colors\"\n              >\n                VIEW_IN_POOL\n              </button>\n            </div>\n          )}\n        </main>\n      )}\n\n      <footer className=\"border-t-2 border-[var(--border)] px-6 py-4 text-center text-xs text-[var(--muted)]\">\n        ICMA.IO // HackPool\n      </footer>\n    </div>\n  );\n}\n",
